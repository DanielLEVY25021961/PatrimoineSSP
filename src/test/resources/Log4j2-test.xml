<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <!--
        =====================================================================
        CONFIGURATION LOG4J2 POUR LES TESTS
        =====================================================================
        Objectif :
        - conserver une console lisible pour voir clairement Maven ;
        - désactiver l'écriture disque des rolling files sans supprimer la
          configuration d'origine ;
        - garder un fichier pédagogique, multi-lignes, clair et modifiable ;
        - réduire au maximum le bruit Spring / JPA / Hibernate côté logs ;
        - éviter que les tests négatifs attendus (doublon, rollback, etc.)
          réémettent inutilement des traces dans la console.
          
        IMPORTANT :
        - les lignes "Hibernate: ..." émises par "spring.jpa.show-sql=true"
          ne sont PAS pilotées par Log4j2 ;
        - elles doivent être coupées dans application-test.properties ;
        - une stack trace écrite directement par le runner de tests
          n'est pas pilotée par Log4j2 ;
        - en revanche, les traces écrites par Spring / Hibernate via leur
          système de logs peuvent être neutralisées ici.
    -->

    <Properties>

        <!--
            Niveau racine volontairement explicite pour éviter la boucle :
            "Infinite loop in property interpolation of LOG_LEVEL->sys:LOG_LEVEL".
        -->
        <Property name="ROOT_LEVEL">ERROR</Property>

        <!--
            Niveau du code applicatif du projet pendant les tests.
            OFF = silence total.
            ERROR = seulement les erreurs.
            WARN = avertissements + erreurs.
            INFO = plus bavard.
            DEBUG = très bavard (à éviter ici).
            TRACE = maximal.
        -->
        <Property name="APP_LEVEL">OFF</Property>

        <!--
            Niveau Spring global.
            ERROR permet de ne laisser remonter que l'essentiel
            si une catégorie spécifique n'est pas coupée plus bas.
        -->
        <Property name="SPRING_LEVEL">ERROR</Property>

        <!--
            Niveau Hibernate global.
            ERROR permet de ne laisser remonter que l'essentiel
            si une catégorie spécifique n'est pas coupée plus bas.
        -->
        <Property name="HIBERNATE_LEVEL">ERROR</Property>

        <!--
            Pattern lisible et compact pour les tests.
            %M = méthode appelante.
        -->
        <Property name="CONSOLE_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%t] %c{1} %M - %msg%n</Property>

        <!--
            Exemple pédagogique :
            on peut piloter un niveau depuis la ligne de commande Maven avec :
            -DAPP_TEST_LOG_LEVEL=INFO

            MAIS on le laisse COMMENTÉ pour éviter toute ambiguïté ou boucle
            d'interpolation dans cette version de test.

            <Property name="APP_LEVEL">${sys:APP_TEST_LOG_LEVEL:-OFF}</Property>
        -->
    </Properties>

    <Appenders>

        <!--
            Console principale conservée active.
            C'est l'unique sortie de logs voulue pendant les tests.
        -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${CONSOLE_PATTERN}"/>
        </Console>

        <!--
            =================================================================
            ROLLING FILE DÉSACTIVÉ
            =================================================================
            On ne supprime rien : on commente simplement tout le bloc pour
            empêcher l'écriture disque pendant les tests Maven.

            Pour le réactiver plus tard :
            1) décommenter ce bloc ;
            2) décommenter les AppenderRef correspondants plus bas.
        -->
        <!--
        <RollingFile
            name="RollingFile"
            fileName="logs/tests.log"
            filePattern="logs/tests-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout
                pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%t] %c %M - %msg%n"/>
            <Policies>
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="10"/>
        </RollingFile>
        -->

    </Appenders>

    <Loggers>

        <!--
            =================================================================
            LOGGER APPLICATIF DU PROJET
            =================================================================
            OFF pour éviter les logs applicatifs parasites pendant les tests,
            y compris dans les scénarios négatifs attendus.
        -->
        <Logger name="levy.daniel" level="${APP_LEVEL}" additivity="false" includeLocation="true">
            <AppenderRef ref="Console"/>
            <!-- <AppenderRef ref="RollingFile"/> -->
        </Logger>

        <!--
            =================================================================
            SPRING
            =================================================================
            Niveau global Spring.
        -->
        <Logger name="org.springframework" level="${SPRING_LEVEL}" additivity="false" includeLocation="true">
            <AppenderRef ref="Console"/>
            <!-- <AppenderRef ref="RollingFile"/> -->
        </Logger>

        <!--
            Transactions Spring :
            OFF pour supprimer le détail transactionnel
            et les messages de rollback attendus.
        -->
        <Logger name="org.springframework.transaction" level="OFF" additivity="false" includeLocation="true">
            <AppenderRef ref="Console"/>
            <!-- <AppenderRef ref="RollingFile"/> -->
        </Logger>

        <!--
            Intercepteur transactionnel Spring :
            OFF pour éviter les traces autour des commits / rollbacks
            attendus dans les tests négatifs.
        -->
        <Logger name="org.springframework.transaction.interceptor" level="OFF" additivity="false" includeLocation="true">
            <AppenderRef ref="Console"/>
            <!-- <AppenderRef ref="RollingFile"/> -->
        </Logger>

        <!--
            JPA Spring :
            OFF pour supprimer le détail ORM côté Spring.
        -->
        <Logger name="org.springframework.orm.jpa" level="OFF" additivity="false" includeLocation="true">
            <AppenderRef ref="Console"/>
            <!-- <AppenderRef ref="RollingFile"/> -->
        </Logger>

        <!--
            Contexte transactionnel des tests Spring :
            OFF pour éviter les messages de gestion transactionnelle
            spécifiques aux tests d'intégration.
        -->
        <Logger name="org.springframework.test.context.transaction" level="OFF" additivity="false" includeLocation="true">
            <AppenderRef ref="Console"/>
            <!-- <AppenderRef ref="RollingFile"/> -->
        </Logger>

        <!--
            Gestionnaire de contexte Spring Test :
            OFF pour éviter le bruit de cycle de vie des tests
            lorsqu'un scénario négatif attendu provoque un rollback.
        -->
        <Logger name="org.springframework.test.context.TestContextManager" level="OFF" additivity="false" includeLocation="true">
            <AppenderRef ref="Console"/>
            <!-- <AppenderRef ref="RollingFile"/> -->
        </Logger>

        <!--
            =================================================================
            HIBERNATE
            =================================================================
            Niveau global Hibernate.
        -->
        <Logger name="org.hibernate" level="${HIBERNATE_LEVEL}" additivity="false" includeLocation="true">
            <AppenderRef ref="Console"/>
            <!-- <AppenderRef ref="RollingFile"/> -->
        </Logger>

        <!--
            SQL Hibernate via logger :
            OFF pour empêcher les logs SQL lorsqu'ils passent par Log4j2.

            ATTENTION :
            si spring.jpa.show-sql=true, Hibernate peut encore écrire
            directement "Hibernate: ..." dans la console hors Log4j2.
        -->
        <Logger name="org.hibernate.SQL" level="OFF" additivity="false" includeLocation="true">
            <AppenderRef ref="Console"/>
            <!-- <AppenderRef ref="RollingFile"/> -->
        </Logger>

        <!--
            Hibernate 6+ : valeurs bindées JDBC.
            OFF pour supprimer le détail des paramètres SQL.
        -->
        <Logger name="org.hibernate.orm.jdbc.bind" level="OFF" additivity="false" includeLocation="true">
            <AppenderRef ref="Console"/>
            <!-- <AppenderRef ref="RollingFile"/> -->
        </Logger>

        <!--
            Ancien canal Hibernate de détail SQL / types JDBC.
            Gardé à titre didactique, désactivé.
        -->
        <Logger name="org.hibernate.type.descriptor.sql" level="OFF" additivity="false" includeLocation="true">
            <AppenderRef ref="Console"/>
            <!-- <AppenderRef ref="RollingFile"/> -->
        </Logger>

        <!--
            Génération de schéma Hibernate.
            OFF pour éviter les create table / drop table si ces messages
            transitent par le système de logs.
        -->
        <Logger name="org.hibernate.tool.schema" level="OFF" additivity="false" includeLocation="true">
            <AppenderRef ref="Console"/>
            <!-- <AppenderRef ref="RollingFile"/> -->
        </Logger>

        <!--
            AIDEUR SQL EXCEPTION HIBERNATE :
            OFF pour supprimer les messages d'erreur SQL attendus
            dans les tests négatifs, par exemple un doublon provoquant
            une violation de contrainte d'unicité.
        -->
        <Logger name="org.hibernate.engine.jdbc.spi.SqlExceptionHelper" level="OFF" additivity="false" includeLocation="true">
            <AppenderRef ref="Console"/>
            <!-- <AppenderRef ref="RollingFile"/> -->
        </Logger>

        <!--
            Conversion des exceptions Hibernate :
            OFF pour éviter les messages techniques redondants
            lorsqu'une exception SQL attendue est déjà testée
            côté JUnit.
        -->
        <Logger name="org.hibernate.exception" level="OFF" additivity="false" includeLocation="true">
            <AppenderRef ref="Console"/>
            <!-- <AppenderRef ref="RollingFile"/> -->
        </Logger>

        <!--
            Mappage interne des exceptions Hibernate :
            OFF pour éviter les traces supplémentaires autour des
            exceptions de persistance attendues.
        -->
        <Logger name="org.hibernate.internal.ExceptionMapperStandardImpl" level="OFF" additivity="false" includeLocation="true">
            <AppenderRef ref="Console"/>
            <!-- <AppenderRef ref="RollingFile"/> -->
        </Logger>

        <!--
            Loggers possibles à activer ponctuellement pour diagnostic fin.
            Conservés COMMENTÉS pour apprentissage.
        -->
        <!--
        <Logger name="org.springframework.test" level="INFO" additivity="false" includeLocation="true">
            <AppenderRef ref="Console"/>
        </Logger>
        -->

        <!--
        <Logger name="org.hibernate.stat" level="DEBUG" additivity="false" includeLocation="true">
            <AppenderRef ref="Console"/>
        </Logger>
        -->

        <!--
            =================================================================
            ROOT LOGGER
            =================================================================
            ERROR pour ne laisser remonter que l'essentiel non catégorisé.
        -->
        <Root level="${ROOT_LEVEL}">
            <AppenderRef ref="Console"/>
            <!-- <AppenderRef ref="RollingFile"/> -->
        </Root>

    </Loggers>
</Configuration>